.SUBCKT IRS21531DS LO HO COM RT CT VCC VB VS
R_CT CT COM 1E12
R_RT RT COM 1E12
R_HO HO VS 1E12
R_LO LO COM 1E12
R_VB VB VS 1E12
R_VCC VCC COM 1E12
R_VS VS COM 1E12
R_DT DT COM 1M
C_DT DT COM 1P
X_GD_TEMPLATE LO HO COM RT CT VCC VB VS DT IRS21531DS_GD_TEMPLATE
.ENDS IRS21531DS
.SUBCKT IRS21531DS_GD_TEMPLATE LO HO COM RT CT VCC VB VS DT PARAMS: HB_EN=1 SHT_EN=1 P_OFFSET_DT=6E-07 P_SLOPE_DT=-0.0 P_SD_D=
+ 4.999985714285715E-08 P_TH_SD_UP=1.9 P_TH_SD_DW=1.1 P_C_SD_LPF=1.4476482730108395E-10 P_C_TPD=4.9229E-08 P_TH_TPD=0.7449688071 
+ P_C_PW_MIN=1E-10 P_TH_HIN_OFF=0.6 P_TH_LIN_OFF=0.6 P_TH_HIN_ON=3.2 P_TH_LIN_ON=3.2 P_R_HIN_CL=1666666.6666666665 P_R_LIN_CL=
+ 16666666.666666668 P_C_GATE=1E-12 P_RBOND_NMOS=0.01 P_RBOND_PMOS=0.01 P_LO_VGS_NMOS=6.2 P_LO_VGS_PMOS=7.9 P_LPMOS_LAMDA=0.1 
+ P_LPMOS_KP=3E-06 P_LNMOS_LAMDA=0.001 P_LNMOS_KP=1.9E-05 P_HO_VGS_NMOS=6.2 P_HO_VGS_PMOS=7.9 P_HPMOS_LAMDA=0.1 P_HPMOS_KP=3E-06 
+ P_HNMOS_LAMDA=0.001 P_HNMOS_KP=1.9E-05 P_VCC_UVH=11 P_VCC_UVL=9 P_VB_UVL=8 P_VB_UVH=9 P_R_UV_D_H=1428.5714285714287 P_R_UV_D_L=
+ 1428.5714285714287 P_VCC_MIN=3 P_IQ_VCC_MIN=0.00013 P_VB_MIN=3 P_IQ_VB_MIN=3E-05 P_VCC_MAX=14 P_IQ_VCC_MAX=0.0008 P_VB_MAX=14 
+ P_IQ_VB_MAX=6E-05 P_V_LEAK=600 P_I_LEAK=1E-06 P_R_BSD=35 P_N_BSD=1.4534194248417849 P_IS_BSD=9.1E-16
X_RT_VCC_D RT VCC IRS21531DS_ESD_DIO PARAMS: P_V_BV=0.3 P_I_BV=1M
X_COM_RT_D COM RT IRS21531DS_ESD_DIO PARAMS: P_V_BV=0.3 P_I_BV=1M
X_CT_VCC_D CT VCC IRS21531DS_ESD_DIO PARAMS: P_V_BV=0.3 P_I_BV=1M
X_COM_CT_D COM CT IRS21531DS_ESD_DIO PARAMS: P_V_BV=0.3 P_I_BV=1M
X_CL_VCC VCC COM IRS21531DS_CL_DIO PARAMS: P_V_BV=15.4 P_I_BV=5M
X_CL_VB VB VS IRS21531DS_CL_DIO PARAMS: P_V_BV=25 P_I_BV=5M
G_BOOTFET VCC VB VALUE={ TABLE(V(VCC,VB), 0,0, 0.29,0,0.3,1M, 4,12M,14, 55M)* V(LIN_DT_DIG)}
XOSC_INPUT_STAGE VCC COM VCC_UV CT RT HIN_DIG LIN_DIG IRS21531DS_OSC_INPUT_STAGE
XOSC_DEADTIME LIN_DT_DIG HIN_DT_DIG LIN_DIG HIN_DIG VCC COM DT IRS21531DS_OSC_DEADTIME PARAMS: P_SLOPE_DT={P_SLOPE_DT} P_OFFSET_DT=
+ {P_OFFSET_DT} HB_EN={HB_EN} SHT_EN = {SHT_EN}
E_SD_DD SD_DD 0 VALUE={1}
X_HO_STAGE HO HIN_DT_DIG VCC_UV VB_UV SD_DD VB VS IRS21531DS_HO_STAGE PARAMS: P_RBOND_PMOS={P_RBOND_PMOS} P_RBOND_NMOS=
+ {P_RBOND_NMOS} P_C_GATE={P_C_GATE} P_HO_VGS_PMOS={P_HO_VGS_PMOS} P_HPMOS_LAMDA={P_HPMOS_LAMDA} P_HPMOS_KP={P_HPMOS_KP} 
+ P_HO_VGS_NMOS={P_HO_VGS_NMOS} P_HNMOS_LAMDA={P_HNMOS_LAMDA} P_HNMOS_KP={P_HNMOS_KP}
X_LO_STAGE LO LIN_DT_DIG VCC_UV SD_DD VCC COM IRS21531DS_LO_STAGE PARAMS: P_RBOND_PMOS={P_RBOND_PMOS} P_RBOND_NMOS={P_RBOND_NMOS} 
+ P_C_GATE={P_C_GATE} P_LO_VGS_PMOS={P_LO_VGS_PMOS} P_LPMOS_LAMDA={P_LPMOS_LAMDA} P_LPMOS_KP={P_LPMOS_KP} P_LO_VGS_NMOS=
+ {P_LO_VGS_NMOS} P_LNMOS_LAMDA={P_LNMOS_LAMDA} P_LNMOS_KP={P_LNMOS_KP}
X_UV_DETECT VCC_UV VB_UV VCC VB COM VS IRS21531DS_UV_DETECT PARAMS: P_VB_UVL={P_VB_UVL} P_VB_UVH={P_VB_UVH} P_R_UV_D_H={P_R_UV_D_H} 
+ P_VCC_UVL={P_VCC_UVL} P_VCC_UVH={P_VCC_UVH} P_R_UV_D_L={P_R_UV_D_L}
X_CC_EMULATOR VCC COM VB VS IRS21531DS_CC_EMULATOR PARAMS: P_VB_MIN={P_VB_MIN} P_VCC_MIN={P_VCC_MIN} P_IQ_VB_MIN={P_IQ_VB_MIN} 
+ P_IQ_VCC_MIN={P_IQ_VCC_MIN} P_I_LEAK={P_I_LEAK} P_V_LEAK={P_V_LEAK} P_VB_MAX={P_VB_MAX} P_VCC_MAX={P_VCC_MAX} P_IQ_VB_MAX=
+ {P_IQ_VB_MAX} P_IQ_VCC_MAX={P_IQ_VCC_MAX}
.ENDS IRS21531DS_GD_TEMPLATE
.SUBCKT IRS21531DS_OSC_INPUT_STAGE VCC COM VCC_UV CT RT HIN_DIG LIN_DIG
E_TH_LOW TH_LOW 0 VALUE= {V(VCC,COM)*(1/5.9)}
E_TH_MID TH_MID 0 VALUE= {V(VCC,COM)*(1/2.9)}
E_TH_HIGH TH_HIGH 0 VALUE= {V(VCC,COM)*(2/2.9)}
G_RT_UP VCC RT VALUE= {V(VCC,RT)/100 * IF(V(RT_DIG)>0.5,1,0)}
G_RT_DW RT COM VALUE= {V(RT,COM)/100 * IF(V(RT_DIG)>0.5,0,1)}
G_VCC VCC COM VALUE={800U * IF(V(RT_DIG)>0.5,1,0)}
X_IN CT IN_DIG COM TH_HIGH TH_MID VCC_UV IRS21531DS_STP_IDEAL1
X_SD CT SD_DIG_AUX COM TH_MID TH_LOW VCC_UV IRS21531DS_STP_IDEAL1
X_SD_DELAY SD_DIG_AUX SD_DIG IRS21531DS_RC_DELAY_10 PARAMS: P_C_DELAY = 4.999985714285715E-08 P_TH_TPD = 0.5
E_RT_DIG RT_DIG 0 VALUE= {IF(V(IN_DIG)>0.5, 0, 1)* V(VCC_UV)}
E_HIN_DIG HIN_DIG 0 VALUE= {IF(V(IN_DIG)>0.5,1,0) * IF(V(SD_DIG)>0.5,1,0)}
E_LIN_DIG LIN_DIG 0 VALUE= {IF(V(IN_DIG)>0.5,0,1) * IF(V(SD_DIG)>0.5,1,0)}
G_CT_BIAS CT COM VALUE={TABLE( V(CT,COM),0,0,10M,1)*0.02U*V(VCC_UV)}
G_CT_PULLDOWN CT COM VALUE={TABLE( V(CT,COM),0,0,10M,300U)* IF(V(VCC_UV)>0.5,0,1)}
.ENDS IRS21531DS_OSC_INPUT_STAGE
.SUBCKT IRS21531DS_OSC_DEADTIME LIN_DT_DIG HIN_DT_DIG LIN_DIG HIN_DIG VCC COM DT PARAMS: HB_EN=1 SHT_EN=0.0 P_SLOPE_DT=
+ 2.43236451E-05 P_OFFSET_DT=5.4E-07 P_I_DT=1E-06 P_C_DT=10P P_TH_UP=0.5
E_VCC_1V VCC_1V 0 VALUE={TABLE( V(VCC,COM) , 0,0 , 3,0 , 6,1 )}
G_DT VCC DT VALUE={TABLE( V(VCC,DT) , 0,0 , 10M,{P_I_DT} )}
E_HIN_DT HIN_DT_DIG 0 VALUE={IF( V(HON) > {P_TH_UP} , 1.0 , 0.0 )}
E_LIN_DT LIN_DT_DIG 0 VALUE={IF( V(LON) > {P_TH_UP} , 1.0 , 0.0 )}
E_1 LIN_DIG_INV 0 VALUE={1- V(LIN_DIG)}
E_2 HIN_DIG_INV 0 VALUE={1- V(HIN_DIG)}
G_H_DT VCC_1V HON VALUE={TABLE( V(VCC_1V,HON) , 0,0 , 10M, I_DT( V(DT,COM) ) )}
C_H_DT HON 0 {P_C_DT}
R_H_DT HON 0 1E8
S_H_DT HON 0 HIN_DIG_INV 0 IRS21531DS_DT_SW
G_L_DT VCC_1V LON VALUE={TABLE( V(VCC_1V,LON) , 0,0 , 10M, I_DT( V(DT,COM) ) )}
C_L_DT LON 0 {P_C_DT}
R_L_DT LON 0 1E8
S_L_DT LON 0 LIN_DIG_INV 0 IRS21531DS_DT_SW
.FUNC I_DT(V_DT) {{P_C_DT} * {P_TH_UP} / ({P_SLOPE_DT}/{P_I_DT}*V_DT + {P_OFFSET_DT})}
.MODEL IRS21531DS_DT_SW VSWITCH RON=1 ROFF=100MEG VON=0.8 VOFF=0.2
.ENDS IRS21531DS_OSC_DEADTIME
.SUBCKT IRS21531DS_INPUT_STAGE LIN_DD HIN_DD SD_DD LIN HIN SD COM PARAMS: P_SD_D=5E-08 P_TH_SD_UP=2.1 P_TH_SD_DW=1.1 P_C_TPD=
+ 1.9E-07 P_TH_TPD=10E-9 P_TH_HIN_OFF=0.9 P_TH_LIN_OFF=0.9 P_TH_HIN_ON=2.1 P_TH_LIN_ON=2.1 P_C_PW_MIN=42E-9 P_C_SD_LPF=1E-9
X_SD_TH SD SD_DIG COM IRS21531DS_STP_IDEAL PARAMS: P_TH_UP={P_TH_SD_UP} P_TH_DW={P_TH_SD_DW}
X_SD_LPF SD_DIG SD_LPF_DIG IRS21531DS_ADV_FILTER PARAMS: P_C_DELAY = {P_C_SD_LPF}
X_SD_DD SD_LPF_DIG SD_DD IRS21531DS_RC_DELAY_10 PARAMS: P_C_DELAY = {P_SD_D}
X_HIN_TH HIN HIN_DIG COM IRS21531DS_STP_IDEAL PARAMS: P_TH_UP={P_TH_HIN_ON} P_TH_DW={P_TH_HIN_OFF}
X_HIN_LPF HIN_DIG HIN_LPF_DIG IRS21531DS_ADV_FILTER PARAMS: P_C_DELAY = {P_C_PW_MIN}
X_HIN_DD HIN_LPF_DIG HIN_DD IRS21531DS_RC_DELAY_10 PARAMS: P_C_DELAY = {P_C_TPD} P_TH_TPD = {P_TH_TPD}
X_LIN_TH LIN LIN_DIG COM IRS21531DS_STN_IDEAL PARAMS: P_TH_UP={P_TH_LIN_ON} P_TH_DW={P_TH_LIN_OFF}
X_LIN_LPF LIN_DIG LIN_LPF_DIG IRS21531DS_ADV_FILTER PARAMS: P_C_DELAY = {P_C_PW_MIN}
X_LIN_DD LIN_LPF_DIG LIN_DD IRS21531DS_RC_DELAY_10 PARAMS: P_C_DELAY = {P_C_TPD} P_TH_TPD = {P_TH_TPD}
.ENDS IRS21531DS_INPUT_STAGE
.SUBCKT IRS21531DS_OVC_DETECT ITRIP RFE OVC_OUT_CTRL VCC_UV COM PARAMS: P_TH_OVC_UP=0.445 P_TH_OVC_DW=0.375 P_C_ITRIP_LPF=330E-9 
+ P_I_TRIP=2.8E-06 P_TH_RFE_UP=5.2 P_TH_RFE_DW=3.2 P_R_RFE_ON=45 P_C_ITRIP_TO_RFE=1E-9 P_C_ITRIP_TO_OUT=1E-9 P_TH_TPD_ITRIP_TO_RFE=0
R_ITRIP ITRIP COM 800K
X_ITRIP ITRIP OVC_DIG COM IRS21531DS_STP_IDEAL PARAMS: P_TH_UP={P_TH_OVC_UP} P_TH_DW={P_TH_OVC_DW}
X_OVC_LPF OVC_DIG OVC_LPF_DIG IRS21531DS_ADV_FILTER PARAMS: P_C_DELAY = {P_C_ITRIP_LPF}
X_ITRIP_TO_RFE OVC_LPF_DIG RFE_CTRL1 IRS21531DS_RC_DELAY_10 PARAMS: P_C_DELAY = {P_C_ITRIP_TO_RFE} P_TH_TPD={P_TH_TPD_ITRIP_TO_RFE}
X_ITRIP_TO_OUT OVC_LPF_DIG OVC_DD IRS21531DS_RC_DELAY_10 PARAMS: P_C_DELAY = {P_C_ITRIP_TO_OUT}
G_RFE RFE COM VALUE {(V(RFE,COM)/{P_R_RFE_ON})*V(RFE_CTRL)}
X_RFE_TH RFE RFE_DIG COM IRS21531DS_STP_IDEAL PARAMS: P_TH_UP={P_TH_RFE_UP} P_TH_DW={P_TH_RFE_DW}
E_OVC_PLS OVC_PLS 0 VALUE={IF( (V(OVC_DD) > 0.5) | (V(OVC) > 0.5) , 1.0 , 0.0)}
E_OVC OVC 0 VALUE={IF( (V(OVC_PLS) > 0.5) & (V(RFE_DIG) < 0.5) , 1.0 , 0.0)}
E_OUT_CTRL OVC_OUT_CTRL 0 VALUE={V(OVC)}
E_RFE_CTRL RFE_CTRL 0 VALUE={IF( (V(VCC_UV) < 0.5) | (V(RFE_CTRL1) > 0.5) , 1.0 , 0.0 )}
.ENDS IRS21531DS_OVC_DETECT
.SUBCKT IRS21531DS_DEADTIME LIN_DT_DIG HIN_DT_DIG LIN HIN DT VCC COM SD_DD VCC_UV PARAMS: HB_EN=1 SHT_EN=0.0 P_SLOPE_DT=
+ 2.43236451E-05 P_OFFSET_DT=5.4E-07 P_I_DT=1E-06 P_C_DT=10P P_TH_UP=0.5
X_LIN_DT LIN LIN_DD IRS21531DS_RC_DELAY_10 PARAMS: P_C_DELAY = 0.3N
X_HIN_DT HIN HIN_DD IRS21531DS_RC_DELAY_10 PARAMS: P_C_DELAY = 0.1N
E_VCC_1V VCC_1V 0 VALUE={TABLE( V(VCC,COM) , 0,0 , 3,0 , 6,1 )}
G_DT VCC DT VALUE={TABLE( V(VCC,DT) , 0,0 , 10M,{P_I_DT} )}
E_HDT_PLS HIN_DT_PLS 0 VALUE={IF( ((V(HIN_DD) - V(LIN_DD)) > 0.1) | (V(HIN_DT_DIG) > 0.5) | ({HB_EN} < 0.5), 1.0 , 0.0 )}
E_HIN_DT HIN_DT_DIG 0 VALUE={IF( ( ((V(HIN_DT_PLS) > 0.5) & (V(LOFF) > {P_TH_UP})) | {HB_EN} < 0.5 ) & (V(HIN_DD) > 0.5 ) & V(
+ VCC_UV) > 0.5 & V(SD_DD)>0.5 , 1.0 , 0.0 )}
E_LDT_PLS LIN_DT_PLS 0 VALUE={IF( ((V(LIN_DD) - V(HIN_DD)) > 0.1) | (V(LIN_DT_DIG) > 0.5) | ({HB_EN} < 0.5) , 1.0 , 0.0 )}
E_LIN_DT LIN_DT_DIG 0 VALUE={IF( ( ((V(LIN_DT_PLS) > 0.5) & (V(HOFF) > {P_TH_UP})) | {HB_EN} < 0.5 ) & (V(LIN_DD) > 0.5 ) , 1.0 , 
+ 0.0 )}
E_SHT_H SHT_H 0 VALUE={IF( {SHT_EN} > 0.5 , V(HIN_DD) , V(HIN_DT_DIG) )}
E_SHT_L SHT_L 0 VALUE={IF( {SHT_EN} > 0.5 , V(LIN_DD) , V(LIN_DT_DIG) )}
G_H_DT VCC_1V HOFF VALUE={TABLE( V(VCC_1V,HOFF) , 0,0 , 10M, I_DT( V(DT,COM) ) )}
C_H_DT HOFF 0 {P_C_DT}
R_H_DT HOFF 0 1E8
S_H_DT HOFF 0 SHT_H 0 IRS21531DS_DT_SW
G_L_DT VCC_1V LOFF VALUE={TABLE( V(VCC_1V,LOFF) , 0,0 , 10M, I_DT( V(DT,COM) ) )}
C_L_DT LOFF 0 {P_C_DT}
R_L_DT LOFF 0 1E8
S_L_DT LOFF 0 SHT_L 0 IRS21531DS_DT_SW
.FUNC I_DT(V_DT) {{P_C_DT} * {P_TH_UP} / ({P_SLOPE_DT}/{P_I_DT}*V_DT + {P_OFFSET_DT})}
.MODEL IRS21531DS_DT_SW VSWITCH RON=1 ROFF=100MEG VON=0.8 VOFF=0.2
.ENDS IRS21531DS_DEADTIME
.SUBCKT IRS21531DS_HO_STAGE HO HIN_DT_DIG VCC_UV VB_UV SD_DD VB VS PARAMS: P_RBOND_NMOS=10M P_RBOND_PMOS=10M P_C_GATE=1E-12 
+ P_HO_VGS_PMOS=6 P_HPMOS_LAMDA=0.06 P_HPMOS_KP=60U P_HO_VGS_NMOS=6 P_HNMOS_LAMDA=0.05 P_HNMOS_KP=100U
R_HIN_DT_DD HIN_DT_DIG HIN_DT_DD 100
C_HIN_DT_DD HIN_DT_DD 0 1N
E_HIN_PLS HIN_PLS 0 VALUE {IF( (V(HIN_DT_DIG) - V(HIN_DT_DD)) > 0.1 | ((V(HGATE_DIG) > 0.5) & V(HIN_DT_DIG)>0.5), 1.0,0.0 )}
E_HGATE_DIG HGATE_DIG 0 VALUE {IF( (V(VCC_UV) > 0.5 & V(VB_UV) > 0.5 & V(HIN_PLS) > 0.5 & V(SD_DD) > 0.5 ) , 1.0,0.0 )}
R_HGATE HGATE_DIG HGATE 1
C_HGATE HGATE 0 {P_C_GATE}
E_HGATE_P VB HGATE_P VALUE {V(HGATE) * {P_HO_VGS_PMOS} * V(HGATE_DIG)}
E_HGATE_N HGATE_N VS VALUE {(1 - V(HGATE)) * {P_HO_VGS_NMOS} * (1 - V(HGATE_DIG))}
M_HO_PMOS HO HGATE_P VB VB IRS21531DS_HO_PMOS
M_HO_NMOS HO HGATE_N VS VS IRS21531DS_HO_NMOS
.MODEL IRS21531DS_HO_PMOS PMOS (LEVEL=1 VTO=-1 CGSO=100P W=1M L=1U RB=1 RG=10 RS=10M RD={P_RBOND_PMOS} LAMBDA={P_HPMOS_LAMDA} KP=
+ {P_HPMOS_KP} )
.MODEL IRS21531DS_HO_NMOS NMOS (LEVEL=1 VTO=1 CGSO=100P W=1M L=1U RB=1 RG=10 RS=10M RD={P_RBOND_NMOS} LAMBDA={P_HNMOS_LAMDA} KP=
+ {P_HNMOS_KP} )
.ENDS IRS21531DS_HO_STAGE
.SUBCKT IRS21531DS_LO_STAGE LO LIN_DT_DIG VCC_UV SD_DD VCC COM PARAMS: P_RBOND_NMOS=10M P_RBOND_PMOS=10M P_C_GATE=1E-12 
+ P_LO_VGS_PMOS=6 P_LPMOS_LAMDA=0.06 P_LPMOS_KP=60U P_LO_VGS_NMOS=6 P_LNMOS_LAMDA=0.05 P_LNMOS_KP=100U
E_LGATE_DIG LGATE_DIG 0 VALUE {IF( (V(VCC_UV) > 0.5 & V(LIN_DT_DIG) > 0.5 & V(SD_DD) > 0.5 ), 1.0,0.0 )}
R_LGATE LGATE_DIG LGATE 1
C_LGATE LGATE 0 {P_C_GATE}
E_LGATE_P VCC LGATE_P VALUE {V(LGATE) * {P_LO_VGS_PMOS} * V(LGATE_DIG)}
E_LGATE_N LGATE_N COM VALUE {(1 - V(LGATE)) * {P_LO_VGS_NMOS} * (1 - V(LGATE_DIG))}
M_LO_PMOS LO LGATE_P VCC VCC IRS21531DS_LO_PMOS
M_LO_NMOS LO LGATE_N COM COM IRS21531DS_LO_NMOS
.MODEL IRS21531DS_LO_PMOS PMOS (LEVEL=1 VTO=-1 CGSO=100P W=1M L=1U RB=1 RG=10 RS=10M RD={P_RBOND_PMOS} LAMBDA={P_LPMOS_LAMDA} KP=
+ {P_LPMOS_KP} )
.MODEL IRS21531DS_LO_NMOS NMOS (LEVEL=1 VTO=1 CGSO=100P W=1M L=1U RB=1 RG=10 RS=10M RD={P_RBOND_NMOS} LAMBDA={P_LNMOS_LAMDA} KP=
+ {P_LNMOS_KP} )
.ENDS IRS21531DS_LO_STAGE
.SUBCKT IRS21531DS_UV_DETECT VCC_UV VB_UV VCC VB COM VS PARAMS: P_VB_UVL=7 P_VB_UVH=8 P_R_UV_D_H=142857 P_VCC_UVL=8 P_VCC_UVH=9 
+ P_R_UV_D_L=71428
X_VB_UV VB VB_UV_DIG VS IRS21531DS_STP_IDEAL PARAMS: P_TH_UP={P_VB_UVH} P_TH_DW={P_VB_UVL}
E_VB_UVL VB_UVL 0 VALUE {IF( V(VB,VS) < {P_VB_UVL} , 0.0 , 1.0 )}
R_VB_UVL VB_UVL VB_UVL_LPF {P_R_UV_D_H}
C_VB_UVL VB_UVL_LPF 0 1P
E_VB_UVL_PLS VB_UVL_PLS 0 VALUE {IF( V(VB_UVL_LPF) < 0.5 | V(VB_UV) < 0.5 , 0.0 , 1.0 )}
E_VB_UV VB_UV 0 VALUE {IF( V(VB_UV_DIG) < 0.5 & V(VB_UVL_PLS) < 0.5 , 0.0 , 1.0 )}
X_VCC_UV VCC VCC_UV_DIG COM IRS21531DS_STP_IDEAL PARAMS: P_TH_UP={P_VCC_UVH} P_TH_DW={P_VCC_UVL}
E_VCC_UVL VCC_UVL 0 VALUE {IF( V(VCC,COM) < {P_VCC_UVL} , 0.0 , 1.0 )}
R_VCC_UVL VCC_UVL VCC_UVL_LPF {P_R_UV_D_L}
C_VCC_UVL VCC_UVL_LPF 0 1P
E_VCC_UVL_PLS VCC_UVL_PLS 0 VALUE {IF( V(VCC_UVL_LPF) < 0.5 | V(VCC_UV) < 0.5 , 0.0 , 1.0 )}
E_VCC_UV VCC_UV 0 VALUE {IF( V(VCC_UV_DIG) < 0.5 & V(VCC_UVL_PLS) < 0.5 , 0.0 , 1.0 )}
.ENDS IRS21531DS_UV_DETECT
.SUBCKT IRS21531DS_CC_EMULATOR VCC COM VB VS PARAMS: P_VB_MIN=10 P_VCC_MIN=10 P_IQ_VB_MIN=100U P_IQ_VCC_MIN=500U P_I_LEAK=1.0U 
+ P_V_LEAK=650 P_VB_MAX=10 P_VCC_MAX=10 P_IQ_VB_MAX=100U P_IQ_VCC_MAX=500U
G_QB VB VS VALUE {TABLE(V(VB,VS) , 0,0 , 0.1,1U , 1,10U , {P_VB_MIN},{P_IQ_VB_MIN} , {P_VB_MAX},{P_IQ_VB_MAX} )}
R_QB VB VS 1E12
G_QCC VCC COM VALUE {TABLE(V(VCC,COM) , 0,0 , 0.1,1U , 1,10U , {P_VCC_MIN},{P_IQ_VCC_MIN} ,9, {P_IQ_VCC_MIN}, {P_VCC_MAX},
+ {P_IQ_VCC_MAX} )}
R_QCC VCC COM 1E12
G_VB_LEAK VS COM VALUE {TABLE(V(VB,COM) , 0,0 , {P_V_LEAK},{P_I_LEAK})}
R_VB_LEAK VS COM 1E12
.ENDS IRS21531DS_CC_EMULATOR
.SUBCKT IRS21531DS_CL_DIO C A PARAMS: P_V_BV=5 P_I_BV=1
G_CL_DIO C A VALUE {TABLE(V(C,A) , 0,0 , {P_V_BV},0 , {P_V_BV}*1.002,{P_I_BV} , 10*{P_V_BV}, 100*{P_I_BV} )}
C_CL_DIO C A 10F
R_CL_DIO C A 1E12
.ENDS IRS21531DS_CL_DIO
.SUBCKT IRS21531DS_ESD_DIO A C PARAMS: P_V_BV=5 P_I_BV=1
G_ESD_DIO A C VALUE {TABLE(V(A,C) , 0,0 , {P_V_BV}*1.01,0 , {P_V_BV}*1.02,{P_I_BV} , 10*{P_V_BV}, 100*{P_I_BV} )}
C_ESD_DIO A C 10F
R_ESD_DIO A C 1E12
.ENDS IRS21531DS_ESD_DIO
.SUBCKT IRS21531DS_RC_DELAY_10 IN OUT PARAMS: P_C_DELAY = 60E-9 P_TH_TPD = 0.5
X_D1 IN D1 IRS21531DS_RC_DELAY_5 PARAMS: P_C_DELAY = {P_C_DELAY} P_TH_TPD = {P_TH_TPD}
X_D2 D1 OUT IRS21531DS_RC_DELAY_5 PARAMS: P_C_DELAY = {P_C_DELAY} P_TH_TPD = {P_TH_TPD}
